{
  "version": "0.4.4",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.johan-kuijt.moneybird-timer\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test .tmp-tests/tests/**/*.test.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "bump-version": "node scripts/bump-version.js",
    "package": "node scripts/package-plugin.js",
    "package:no-bump": "node scripts/package-plugin.js --no-bump",
    "release": "npm run lint && npm run typecheck && npm run test && npm run build && npm run package"
  },
  "type": "module",
  "devDependencies": {
    "@elgato/cli": "^1.7.1",
    "@eslint/js": "^9.39.2",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "~25.5.0",
    "archiver": "^7.0.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "rollup": "^4.57.1",
    "tslib": "^2.6.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.1",
    "axios": "^1.13.5",
    "date-fns": "^4.1.0"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
