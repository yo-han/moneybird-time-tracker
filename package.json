{
  "version": "0.4.4",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.johan-kuijt.moneybird-timer\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test .tmp-tests/tests/**/*.test.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "bump-version": "node scripts/bump-version.js",
    "package": "node scripts/package-plugin.js",
    "package:no-bump": "node scripts/package-plugin.js --no-bump",
    "release": "npm run lint && npm run typecheck && npm run test && npm run build && npm run package"
  },
  "type": "module",
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "@eslint/js": "^9.39.2",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "~25.9.2",
    "archiver": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "rollup": "^4.61.1",
    "tslib": "^2.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0",
    "axios": "1.17.0",
    "date-fns": "^4.4.0"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "serialize-javascript": "^7.0.5",
    "picomatch": "^4.0.4",
    "flatted": "^3.4.2",
    "tar": "^7.5.13",
    "fast-uri": "3.1.2"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
